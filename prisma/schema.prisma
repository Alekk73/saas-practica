generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma_client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id            String               @id             @default(uuid())
  name          String               @unique
  users         User[]
  subscriptions SubscriptionTenant[]
  created_at    DateTime             @default(now()) @db.Timestamptz(6)
  updated_at    DateTime             @updatedAt      @db.Timestamptz(6)

  @@map("tenants")
}

model User {
  id               String       @id @default(uuid())
  tenant_id        String
  tenant           Tenant       @relation(fields: [tenant_id], references: [id])
  name             String
  lastname         String
  email            String       @unique
  password_hash    String
  role             UserRole     @default(USER)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @updatedAt      @db.Timestamptz(6)

  @@index([tenant_id])
  @@map("users")
}

model Subscription {
  id         String               @id @default(uuid())
  type       SubscriptionType
  tenants    SubscriptionTenant[]
  created_at DateTime             @default(now()) @db.Timestamptz(6)
  updated_at DateTime             @updatedAt      @db.Timestamptz(6)

  @@map("subscriptions")
}

model SubscriptionTenant {
  tenant_id       String
  tenant          Tenant       @relation(fields: [tenant_id], references: [id])
  subscription_id String
  subscription    Subscription @relation(fields: [subscription_id], references: [id])

  @@id([tenant_id, subscription_id])
  @@index([subscription_id])
  @@map("subscriptions_tenants")
}

enum UserRole {
  ADMIN @map("admin")
  USER  @map("user")

  @@map("user_roles")
}

enum SubscriptionType {
  SERVICE  @map("service")
  COMMERCE @map("commerce")

  @@map("subscription_types")
}
